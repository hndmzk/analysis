AUDIT_NOTIFY_ON_OK=false
AUDIT_NOTIFY_DRY_RUN=false
AUDIT_NOTIFY_INCLUDE_WATCH_ONLY=true
AUDIT_SLACK_WEBHOOK_URL=
AUDIT_EMAIL_SMTP_HOST=
AUDIT_EMAIL_SMTP_PORT=587
AUDIT_EMAIL_USE_TLS=true
AUDIT_EMAIL_SMTP_USER=
AUDIT_EMAIL_SMTP_PASSWORD=
AUDIT_EMAIL_FROM=
AUDIT_EMAIL_TO=
